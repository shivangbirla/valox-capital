# ---------------------------------------------------------------------------
# Valox Capital — environment variables (all optional)
# Copy this file to ".env" and fill in values to override the defaults.
# ---------------------------------------------------------------------------

# Published Google Sheet CSV URL for the live NAV chart.
# In Google Sheets: File -> Share -> Publish to web -> (this sheet) -> CSV.
# Columns: date (YYYY-MM-DD), nav (number). Leave blank to use bundled sample data.
VITE_NAV_SHEET_URL=

# Web3Forms access key for the contact / lead form — https://web3forms.com
# A working key ships with the app; set this to route submissions to your own inbox.
VITE_WEB3FORMS_ACCESS_KEY=
